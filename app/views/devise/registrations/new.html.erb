<h1 class="page-title">Sign Up</h1>
<p class="page-subtitle">Create your learning account.</p>

<div class="card">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
    </div>

    <div class="field">
      <%= f.label :password %>
      <%= f.password_field :password, autocomplete: "new-password", id: "new_user_password" %>
    </div>

    <div class="field">
      <%= f.label :password_confirmation %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", id: "new_user_password_confirmation" %>
    </div>

    <div class="field">
      <label>
        <input type="checkbox" data-password-toggle-targets="new_user_password,new_user_password_confirmation">
        Show passwords
      </label>
    </div>

    <%= f.submit "Sign Up", class: "btn" %>
  <% end %>
</div>

<div class="actions">
  <%= render "devise/shared/links" %>
</div>
