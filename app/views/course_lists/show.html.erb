<h1 class="page-title"><%= @course.title %></h1>
<p class="page-subtitle"><%= @course.description.presence || "No description available." %></p>

<div class="card">
  <strong>Progress: <%= @progress_percent %>%</strong>
  <div class="progress">
    <div class="progress-bar" style="width: <%= @progress_percent %>%"></div>
  </div>

  <% if @quiz_available %>
    <p class="page-subtitle">
      Final quiz: <%= @quiz_completed ? "Completed" : "Pending" %>
      (<%= @course.course_quiz_questions.size %> questions)
    </p>
    <div class="actions">
      <%= link_to(@quiz_completed ? "Open Final Quiz" : "Attempt Final Quiz", course_list_quiz_path(@course), class: "btn") %>
    </div>
  <% end %>

  <% if @all_sections_completed && (!@quiz_available || @quiz_completed) && !@course_completed %>
    <div class="actions">
      <%= button_to "Complete Course", complete_course_list_path(@course), method: :post, class: "btn" %>
    </div>
  <% end %>

  <% if @course_completed && @first_section.present? %>
    <p class="page-subtitle"><strong>Course completed.</strong></p>
    <div class="actions">
      <%= link_to "Learn Again", course_list_course_list_section_path(@course, @first_section), class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h2>Sections</h2>

  <% if @sections.any? %>
    <ol class="section-list">
      <% @sections.each_with_index do |section, index| %>
        <% current_completed = @completed_section_ids.include?(section.id) %>
        <li class="section-item">
          <div>
            <div class="section-item-title">
              <%= link_to section.title, course_list_course_list_section_path(@course, section) %>
            </div>
            <small>Section <%= index + 1 %></small>
          </div>
          <div class="section-item-meta">
            <% if current_completed %>
              <span class="badge">Completed</span>
            <% end %>
            <%= link_to "Open", course_list_course_list_section_path(@course, section), class: "btn btn-secondary" %>
          </div>
        </li>
      <% end %>

      <% if @quiz_available %>
        <li class="section-item">
          <div>
            <div class="section-item-title">Final Quiz</div>
            <small>Final Step</small>
          </div>
      <div class="section-item-meta">
        <% if @quiz_completed %>
          <span class="badge">Completed</span>
        <% else %>
          <span class="badge">Pending</span>
        <% end %>
      </div>
    </li>
  <% end %>
    </ol>
  <% else %>
    <p>No sections available yet.</p>
  <% end %>
</div>

<div class="actions">
  <%= link_to "Back to Courses", course_lists_path, class: "btn btn-secondary" %>
</div>
