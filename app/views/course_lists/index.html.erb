<section class="academy-dashboard">
  <article class="academy-panel academy-overview">
    <h1><%= @frontpage.overview_title %></h1>
    <p class="academy-subtitle"><%= @frontpage.overview_subtitle %></p>

    <% if current_user.super_admin? %>
      <div class="actions academy-overview-edit">
        <%= link_to "Edit Overview Content", edit_admin_frontpage_content_path, class: "btn btn-secondary" %>
      </div>
    <% end %>

    <div class="academy-overview-content">
      <div class="academy-media">
        <% if @overview_video_attachment.present? %>
          <%= video_tag url_for(@overview_video_attachment), controls: true, preload: "metadata", class: "academy-intro-video" %>
        <% elsif @featured_video&.file&.attached? %>
          <%= video_tag url_for(@featured_video.file), controls: true, preload: "metadata", class: "academy-intro-video" %>
        <% else %>
          <div class="academy-media-placeholder">
            <p>Intro Video</p>
          </div>
        <% end %>
      </div>

      <p class="academy-overview-copy"><%= @frontpage.overview_body %></p>
    </div>
  </article>

  <article class="academy-panel academy-learning">
    <h2><%= @frontpage.learning_panel_title %></h2>

    <% if @course_lists.any? %>
      <div class="academy-course-list">
        <% @course_lists.each do |course| %>
          <div class="academy-course-row">
            <%= link_to "Start learning", course_list_path(course), class: "academy-start-btn" %>
            <h3><%= link_to course.title, course_list_path(course) %></h3>
          </div>
        <% end %>
      </div>
    <% else %>
      <p>No courses are visible for your union yet.</p>
    <% end %>
  </article>
</section>
