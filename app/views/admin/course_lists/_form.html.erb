<%= form_with model: [:admin, @course_list] do |f| %>
  <% if @course_list.errors.any? %>
    <div class="flash alert">
      <h2><%= pluralize(@course_list.errors.count, "error") %> prevented this course from saving:</h2>
      <ul class="list">
        <% @course_list.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div class="field">
    <%= f.label :description %>
    <%= f.text_area :description, rows: 5 %>
  </div>

  <div class="field">
    <label>Visible to unions</label>
    <%= f.collection_check_boxes :union_ids, @available_unions, :id, :name %>
  </div>

  <div class="card">
    <div class="nested-section-head">
      <h2>Sections</h2>
      <button type="button" class="btn" data-modal-open="course-section-picker">Section</button>
    </div>
    <p class="page-subtitle">Click Section to choose what you want to add first. You can add Text/Video/Image after opening each section.</p>

    <div data-sections-container>
      <%= f.fields_for :course_list_sections do |section_fields| %>
        <%= render "section_fields", f: section_fields %>
      <% end %>
    </div>

    <template id="section-template">
      <% section = CourseListSection.new %>
      <%= f.fields_for :course_list_sections, section, child_index: "NEW_SECTION" do |section_fields| %>
        <%= render "section_fields", f: section_fields %>
      <% end %>
    </template>
  </div>

  <div class="modal-backdrop" data-modal="course-section-picker" hidden>
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="course-section-picker-title">
      <h2 id="course-section-picker-title">Section Options</h2>
      <p class="page-subtitle">Choose content type. A new section will be added, then you can add selected content in that section page.</p>

      <div class="modal-actions">
        <button type="button" class="btn" data-create-section="text">Text</button>
        <button type="button" class="btn" data-create-section="video">Video</button>
        <button type="button" class="btn" data-create-section="image">Image</button>
        <button type="button" class="btn" data-add-quiz-question>Quiz</button>
      </div>

      <div class="actions">
        <button type="button" class="btn btn-secondary" data-modal-close="course-section-picker">Close</button>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="nested-section-head">
      <h2>Final Quiz Questions</h2>
      <button type="button" class="btn" data-add-quiz-question>Add Question</button>
    </div>
    <p class="page-subtitle">Users will answer these questions after all course sections are completed.</p>

    <div data-quiz-questions-container>
      <%= f.fields_for :course_quiz_questions do |quiz_question_fields| %>
        <%= render "quiz_question_fields", f: quiz_question_fields %>
      <% end %>
    </div>

    <template data-quiz-question-template>
      <%= f.fields_for :course_quiz_questions, CourseQuizQuestion.new, child_index: "NEW_QUIZ_QUESTION" do |quiz_question_fields| %>
        <%= render "quiz_question_fields", f: quiz_question_fields %>
      <% end %>
    </template>
  </div>

  <%= f.submit "Save Course", class: "btn" %>
<% end %>
