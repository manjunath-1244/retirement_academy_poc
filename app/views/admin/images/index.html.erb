<h1 class="page-title">Images: <%= @section.title %></h1>

<div class="actions">
  <%= link_to "Add Image", new_admin_course_list_course_list_section_image_path(@course_list, @section), class: "btn" %>
  <%= link_to "Back to Section", admin_course_list_course_list_section_path(@course_list, @section), class: "btn btn-secondary" %>
</div>

<% if @images.any? %>
  <div class="grid">
    <% @images.each do |image| %>
      <div class="card">
        <p><strong><%= image.title %></strong></p>
        <% if image.file.attached? %>
          <%= image_tag url_for(image.file), class: "content-image" %>
        <% else %>
          <p>No file attached.</p>
        <% end %>
        <div class="actions">
          <%= link_to "Edit", edit_admin_course_list_course_list_section_image_path(@course_list, @section, image), class: "btn btn-secondary" %>
          <%= button_to "Delete", admin_course_list_course_list_section_image_path(@course_list, @section, image), method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Delete image?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card"><p>No images yet.</p></div>
<% end %>
