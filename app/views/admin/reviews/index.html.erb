<h1 class="page-title">Review Questions: <%= @section.title %></h1>

<div class="actions">
  <%= link_to "Add Review", new_admin_course_list_course_list_section_review_path(@course_list, @section), class: "btn" %>
  <%= link_to "Back to Section", admin_course_list_course_list_section_path(@course_list, @section), class: "btn btn-secondary" %>
</div>

<% if @reviews.any? %>
  <div class="grid">
    <% @reviews.each do |review| %>
      <div class="card">
        <p><strong>Q:</strong> <%= review.question %></p>
        <p><strong>A:</strong> <%= review.answer %></p>
        <div class="actions">
          <%= link_to "Edit", edit_admin_course_list_course_list_section_review_path(@course_list, @section, review), class: "btn btn-secondary" %>
          <%= button_to "Delete", admin_course_list_course_list_section_review_path(@course_list, @section, review), method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Delete review?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card"><p>No review questions yet.</p></div>
<% end %>
