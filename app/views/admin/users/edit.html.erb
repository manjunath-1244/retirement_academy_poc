<h1 class="page-title">Edit User</h1>

<div class="card">
  <p><strong>Email:</strong> <%= @user.email %></p>

  <%= form_with model: [:admin, @user] do |f| %>
    <% if current_user.super_admin? %>
      <div class="field">
        <%= f.label :role %>
        <%= f.select :role, User::ASSIGNABLE_ROLES.map { |role| [role.humanize, role] } %>
      </div>
    <% end %>

    <div class="field">
      <label>Unions</label>
      <div class="actions">
        <button type="button" class="btn btn-secondary" data-select-action="all" data-select-target="user-unions">Select All Unions</button>
        <button type="button" class="btn btn-secondary" data-select-action="none" data-select-target="user-unions">Clear All Unions</button>
      </div>
      <div id="user-unions" class="multi-select-list">
        <%= f.collection_check_boxes :union_ids, @available_unions, :id, :name, checked: @selected_union_ids %>
      </div>
    </div>

    <%= f.submit "Update User", class: "btn" %>
  <% end %>
</div>

<div class="actions">
  <%= link_to "Back", admin_users_path, class: "btn btn-secondary" %>
</div>
